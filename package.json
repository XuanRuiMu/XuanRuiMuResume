{
  "name": "xuanruimu-resume",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "玄锐暮 AI-Native Developer Résumé Hub — 内容优先的在线简历，融合 AI 问答、Cmd+K 命令面板、技能雷达图与 PWA",
  "scripts": {
    "optimize:fonts": "node scripts/subset-fonts.js",
    "optimize:assets": "npm run optimize:fonts",
    "dev": "npm run optimize:assets && vite --host --port 5180",
    "build": "npm run optimize:assets && tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "oxlint . && eslint .",
    "lint:fix": "oxlint . --fix && eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json,md}\" \"scripts/**/*.{js,ts}\" \"*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json,md}\" \"scripts/**/*.{js,ts}\" \"*.{js,ts,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pwa": "vitest run src/sw.test.ts",
    "test:e2e": "playwright test",
    "analyze": "npm run optimize:assets && ANALYZE=true vite build",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.2",
    "ai": "^7.0.17",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@fontpkg/smiley-sans": "^2.0.4",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.1",
    "oxlint": "^1.69.0",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.35.3",
    "subset-font": "^2.5.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.0",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
